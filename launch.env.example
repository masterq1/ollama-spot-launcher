# Shared identifiers
INSTANCE_PROFILE="OllamaSpotProfile"
NOTIFY_EMAIL="you@example.com"
SNS_TOPIC_NAME="OllamaSpotNotify"
WEBHOOK_URL="https://your-webhook-domain.example.com"

# Instance + spot pricing
INSTANCE_TYPE="g5.xlarge"
SPOT_MAX_PRICE="2.50"
SPOT_WAIT_MAX=600                 # seconds to wait for spot fulfillment before giving up

# EBS root volume
EBS_SIZE_GB=100
EBS_TYPE="gp3"
EBS_IOPS=3000
EBS_THROUGHPUT=250
EBS_DELETE_ON_TERMINATION=false   # false = retain EBS after instance terminates; true = delete

# Webhook callback
WEBHOOK_PORT=8765
WEBHOOK_WAIT_MAX=1500             # seconds to wait for model_ready before giving up
WEBHOOK_SECRET_FILE="$HOME/.ollama_webhook_secret"

# us-east-1 — g5.xlarge Qwen3-32B
KEY_PAIR_USE1="your-key-pair-name"
SECURITY_GROUP_ID_USE1="sg-xxxxxxxxxxxxxxxxx"
SUBNET_ID_USE1="subnet-xxxxxxxx"
AMI_ID_USE1="ami-xxxxxxxxxxxxxxxxx"
# g5.12xlarge Qwen2.5-72B AMIs per AZ (commented out for now)
# AMI_ID_USE1_12XL_A="ami-xxxxxxxxxxxxxxxxx"   # us-east-1a
# AMI_ID_USE1_12XL_B="ami-xxxxxxxxxxxxxxxxx"   # us-east-1b

# us-east-2 — g5.xlarge Qwen3-32B
KEY_PAIR_USE2="your-key-pair-name"
SECURITY_GROUP_ID_USE2="sg-xxxxxxxxxxxxxxxxx"
SUBNET_ID_USE2="subnet-xxxxxxxx"
AMI_ID_USE2="ami-xxxxxxxxxxxxxxxxx"
# g5.12xlarge Qwen2.5-72B AMIs per AZ (commented out for now)
# AMI_ID_USE2_12XL_A="ami-xxxxxxxxxxxxxxxxx"   # us-east-2a
# AMI_ID_USE2_12XL_B="ami-xxxxxxxxxxxxxxxxx"   # us-east-2b
